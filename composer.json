{
  "name": "newtxt/newtxt-translate",
  "description": "Laravel integration package for NewTXT Translate widget rendering, server-side localization, translated HTML cache, and prewarm workflows.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "localization",
    "translation",
    "widget",
    "seo",
    "newtxt"
  ],
  "homepage": "https://github.com/galdarturin/WidgetTranslateLaravel",
  "support": {
    "issues": "https://github.com/galdarturin/WidgetTranslateLaravel/issues",
    "source": "https://github.com/galdarturin/WidgetTranslateLaravel"
  },
  "authors": [
    {
      "name": "NewTXT",
      "homepage": "https://newtxt.io",
      "role": "Developer"
    }
  ],
  "autoload": {
    "psr-4": {
      "Newtxt\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Newtxt\\Laravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Newtxt\\Laravel\\NewtxtServiceProvider"
      ],
      "aliases": {
        "Newtxt": "Newtxt\\Laravel\\Facades\\Newtxt"
      }
    }
  },
  "require": {
    "php": "^8.2",
    "ext-dom": "*",
    "ext-json": "*",
    "ext-simplexml": "*",
    "illuminate/cache": "^10.0|^11.0|^12.0",
    "illuminate/console": "^10.0|^11.0|^12.0",
    "illuminate/contracts": "^10.0|^11.0|^12.0",
    "illuminate/filesystem": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "phpunit/phpunit": "^10.5|^11.5|^12.0"
  },
  "scripts": {
    "lint": "find config src tests -name '*.php' -print0 | xargs -0 -n1 php -l",
    "test": "phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
